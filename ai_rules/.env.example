# CONFIG: Copy this file to <workspace-root>\secrets\ai_rules\.env and fill in the real values.

# CONFIG: Verify the current Notion API version in official docs if needed.
NOTION_TOKEN=
NOTION_VERSION=2026-03-11

# CONFIG: Path to the OAuth desktop client JSON downloaded from Google Cloud.
GOOGLE_OAUTH_CLIENT_FILE=<workspace-root>\secrets\ai_rules\google-oauth-client.json

# CONFIG: Local token cache path created after the first Google OAuth browser login.
GOOGLE_OAUTH_TOKEN_FILE=<workspace-root>\secrets\ai_rules\google-oauth-token.json
