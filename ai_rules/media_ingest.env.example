# Copy this file to ~/.config/ai-rules-media-ingest/.env from Kali WSL and fill in the real values.

NOTION_TOKEN=
NOTION_VERSION=2026-03-11

# First run creates the database under this page.
MEDIA_INGEST_PARENT_PAGE_ID=

# Optional overrides. Leave blank on the first run and the script will store them in state.json.
MEDIA_INGEST_DATABASE_ID=
MEDIA_INGEST_DATA_SOURCE_ID=

MEDIA_INGEST_DATABASE_TITLE=Media Library
MEDIA_LIBRARY_ROOT=./raw-media-downloads
MEDIA_INGEST_STATE_PATH=~/.config/ai-rules-media-ingest/state.json

YT_DLP_BIN=yt-dlp
FFPROBE_BIN=ffprobe
FFMPEG_BIN=ffmpeg
